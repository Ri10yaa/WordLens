{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-dictionary/schema/contextual_meaning.json",
  "title": "ContextualMeaningResponse",
  "type": "object",
  "properties": {
    "word": {
      "type": "string"
    },
    "definition": {
      "type": ["string", "null"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sense_id": {
      "type": ["string", "null"]
    }
  },
  "required": ["word", "confidence"],
  "additionalProperties": false
}
